{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "*"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Key": "CHANGE_ME_IN_PRODUCTION_minimum_32_chars!!",
    "Issuer": "CRMService",
    "Audience": "CRMServiceClients",
    "ExpiresInMinutes": 60,
    "RefreshTokenExpiresInDays": 7
  }
}
